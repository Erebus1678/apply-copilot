# --- AI provider layer (provider-agnostic) ---
# Default provider: local | ollama | openai | anthropic | openrouter | groq | together
AI_PROVIDER=local

# Local OpenAI-compatible servers (no key needed).
LOCAL_AI_BASE_URL=http://localhost:1234/v1   # LM Studio
LOCAL_AI_MODEL=qwen/qwen3-coder-30b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Cloud providers (optional — only the one(s) you select need a key).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# OpenRouter — one key, many models (great for self-host / future SaaS).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# 9Router (https://github.com/decolua/9router) — local OpenAI-compatible router
# with auto-fallback + RTK token saving. Keyless on localhost. Run it, then pick
# "9Router" in the header. Override the URL/model if you changed 9Router's port.
NINEROUTER_BASE_URL=http://localhost:20128/v1
NINEROUTER_MODEL=gpt-4o-mini

# --- Token savers ---
# Built-in prompt compression always runs (whitespace/boilerplate trim).
# Optional external compress proxy (Headroom-style). When set, prompt text is
# POSTed to this URL ({ text } -> { text }) before provider routing. OFF unless set.
# NOTE: this sends prompt text off the box — opt-in egress.
COMPRESS_PROXY_URL=
COMPRESS_PROXY_TOKEN=

# --- Limits (optional — defaults match the previous hardcoded values) ---
# AI endpoints are IP-rate-limited in-memory (per instance). Tune for your box:
AI_RATE_LIMIT=20          # max AI requests per window per IP
AI_RATE_WINDOW_MS=60000   # window length in ms (min 1000)
# CV upload ceiling in bytes (default 5 MB; raise for high-res scanned résumés):
CV_MAX_BYTES=5242880

# --- Persistence (pipeline board) ---
# OPTIONAL. Leave DATABASE_URL empty for the OSS default: an embedded PGlite
# database (a local file under ./data, auto-migrated on first boot — zero setup).
# Set DATABASE_URL to a server Postgres (Supabase/Neon) for the hosted/SaaS path:
#  DATABASE_URL = Transaction pooler (port 6543) — used by the app at runtime.
#  DIRECT_URL   = Direct/Session connection (port 5432) — used to run migrations.
# PGLITE_PATH overrides the local DB dir (default ./data/pgdata).
DATABASE_URL=
DIRECT_URL=
PGLITE_PATH=
