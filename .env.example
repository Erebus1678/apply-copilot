# --- AI provider layer (provider-agnostic) ---
# Which provider to use by default: "local" | "openai" | "anthropic"
AI_PROVIDER=local

# Local OpenAI-compatible server (e.g. LM Studio). No key needed.
LOCAL_AI_BASE_URL=http://localhost:1234/v1
LOCAL_AI_MODEL=qwen/qwen3-coder-30b

# Cloud providers (optional — only needed when AI_PROVIDER is set to them).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Persistence (Phase 4 pipeline board) ---
# Supabase Postgres. From the project's "Connect" dialog:
#  DATABASE_URL = Transaction pooler (port 6543) — used by the app at runtime.
#  DIRECT_URL   = Direct/Session connection (port 5432) — used to run migrations.
DATABASE_URL=
DIRECT_URL=
